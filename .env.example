# FastAPI
APP_NAME=Face ID Backend
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Qdrant Cloud
QDRANT_URL=https://your-cluster-url.qdrant.tech
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=image
QDRANT_VECTOR_SIZE=512
QDRANT_DISTANCE_METRIC=cosine

# Supabase Storage (S3 compatible)
SUPABASE_S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
SUPABASE_BUCKET=your_bucket_name
SUPABASE_ACCESS_KEY=your_supabase_s3_access_key
SUPABASE_SECRET_KEY=your_supabase_s3_secret_key
SUPABASE_S3_REGION=us-east-1
# Optional override for public URL base.
# If unset, service builds URL as: https://<project>.supabase.co/storage/v1/object/public/<bucket>/<key>
SUPABASE_PUBLIC_BASE_URL=

# Embedding API
# Use your space ID or direct URL compatible with gradio_client.Client(...)
EMBEDDING_API_URL=arafat216/face-resnet50-v1
EMBEDDING_API_NAME=/get_embedding
EMBEDDING_API_MAX_RETRIES=3
EMBEDDING_API_RETRY_DELAY_SECONDS=1.5

# Upload and search controls
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
MAX_IMAGE_SIZE_MB=10
FIXED_TOP_K=5
MIN_MATCH_SCORE=0.4
